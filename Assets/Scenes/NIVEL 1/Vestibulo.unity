--- !u!114 &753413510
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 753413507}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0df5a9f58bc322843904d883b2ed7c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogoInicial:
    dialogueLines:
    - character:
        name: Guardia
        icon: {fileID: -7321020658954786541, guid: 4c4f51b4c3c209c4f9b6be0bed83b42a, type: 3}
      line: "Atr\xE1s, Red Fox. El sal\xF3n de baile est\xE1 cerrado por orden directa
        de Basil. Hay una reuni\xF3n privada de los Knickerbocker."
    - character:
        name: Elvira
        icon: {fileID: -6177139537827096713, guid: 7f3b39185ede8c143932d888e56047ab, type: 3}
      line: "Querido, sabes que mi p\xFAblico me espera ah\xED dentro. No querr\xE1s
        que el espect\xE1culo se retrase, \xBFverdad?"
    - character:
        name: Guardia
        icon: {fileID: -7321020658954786541, guid: 4c4f51b4c3c209c4f9b6be0bed83b42a, type: 3}
      line: "Me importa un bledo tu espect\xE1culo. Mi orden es que nadie pase por
        esta puerta. A menos que el speakeasy se est\xE9 quemando, yo de aqu\xED
        no me muevo."
  dialogoProgreso:
    dialogueLines:
    - character:
        name: Guardia
        icon: {fileID: -7321020658954786541, guid: 4c4f51b4c3c209c4f9b6be0bed83b42a, type: 3}
      line: "\xBFSigues aqu\xED? Te lo he dicho: a menos que haya una emergencia
        real, nadie entra. Vete a ensayar tus canciones a otra parte."
  dialogoFinalizado:
    dialogueLines: []
  objetivoCumplido: 0
