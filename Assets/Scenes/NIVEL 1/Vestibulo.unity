--- !u!114 &978163973
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 978163969}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0df5a9f58bc322843904d883b2ed7c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogoInicial:
    dialogueLines:
    - character:
        name: Dra.Zina
        icon: {fileID: 2842594032047097641, guid: bfa6f266c276ab840b89f053a8a2bfbe, type: 3}
      line: "Elvira... siempre tan puntual para los problemas. \xBFHas o\xEDdo los
        rumores? Basil ha estado hablando m\xE1s de la cuenta. Dice que a las 19:40
        esto se llenar\xE1 de uniformados."
    - character:
        name: Elvira
        icon: {fileID: -6177139537827096713, guid: 7f3b39185ede8c143932d888e56047ab, type: 3}
      line: "He o\xEDdo que el Teniente O'Malley tiene ganas de colgarse una medalla
        a nuestra costa. \xBFQu\xE9 hay en ese malet\xEDn, Zina?"
    - character:
        name: Dra.Zina
        icon: {fileID: 2842594032047097641, guid: bfa6f266c276ab840b89f053a8a2bfbe, type: 3}
      line: "Mi seguro de vida. La c\xE1psula de cianuro que Basil me rob\xF3 de
        Columbia. Si la polic\xEDa llega y registra este lugar antes de que 'limpiemos'
        el nombre de Basil de la lista de los vivos, estamos muertas."
    - character:
        name: Dra.Zina
        icon: {fileID: 2842594032047097641, guid: bfa6f266c276ab840b89f053a8a2bfbe, type: 3}
      line: "Necesito esa c\xE1psula para su petit four de frambuesa. El c\xF3digo
        es el a\xF1o en que empez\xF3 nuestra sociedad en el Waldorf, pero Basil
        es un paranoico... puso la fecha al rev\xE9s. \xC1brelo antes de que el Wolf
        asome el hocico por la puerta."
  dialogoProgreso:
    dialogueLines:
    - character:
        name: Dra.Zina
        icon: {fileID: 2842594032047097641, guid: bfa6f266c276ab840b89f053a8a2bfbe, type: 3}
      line: "A\xFAn no ha llegado O'Malley, pero puedo oler el miedo en el ambiente.
        \xBFHas descifrado ya el a\xF1o invertido?"
  dialogoFinalizado:
    dialogueLines:
    - character:
        name: Dra.Zina
        icon: {fileID: 2842594032047097641, guid: bfa6f266c276ab840b89f053a8a2bfbe, type: 3}
      line: "Aqu\xED tienes. Una peque\xF1a c\xE1psula para un gran problema."
  objetivoCumplido: 0
