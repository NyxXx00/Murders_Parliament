--- !u!114 &954360745
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 954360742}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 96f50e80341193944b7ed89703c831cd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  posicionMesaAmigo: {fileID: 1538482112}
  scriptVaso: {fileID: 1280265939}
  pensamientoProtagonista:
    dialogueLines: []
  taskID: 10
  velocidad: 1.5
  pensamientoLuegoDeQueSeVa:
    dialogueLines:
    - character:
        name: Elvira
        icon: {fileID: -6177139537827096713, guid: 7f3b39185ede8c143932d888e56047ab, type: 3}
      line: "Se ha ido... es mi oportunidad. Veamos qu\xE9 hay en ese vaso antes
        de que alguien m\xE1s se acerque."
--- !u!114 &954360746
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 954360742}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0df5a9f58bc322843904d883b2ed7c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogoInicial:
    dialogueLines:
    - character:
        name: Big Bear Romanov
        icon: {fileID: 1547146456086501955, guid: 59fb5021777d2914085416755ad69238, type: 3}
      line: "Eh... busca tu propia miel, colega. Este vaso y yo tenemos una reuni\xF3n
        privada."
    - character:
        name: Big Bear Romanov
        icon: {fileID: 1547146456086501955, guid: 59fb5021777d2914085416755ad69238, type: 3}
      line: "Si buscas conversaci\xF3n, habla con la pared. Ella escucha mejor que
        yo ahora mismo."
  dialogoProgreso:
    dialogueLines:
    - character:
        name: Elvira
        icon: {fileID: -6177139537827096713, guid: 7f3b39185ede8c143932d888e56047ab, type: 3}
      line: "\xBFEst\xE1s bien? Pareces... alterado."
    - character:
        name: Big Bear Romanov
        icon: {fileID: 1547146456086501955, guid: 59fb5021777d2914085416755ad69238, type: 3}
      line: "\xBFBien? \xA1Ja! Me prometieron que esta noche ser\xEDa tranquila.
        Pero luego apareci\xF3 \xE9l... con sus modales de seda y ese pelaje tan...
        tan..."
    - character:
        name: Big Bear Romanov
        icon: {fileID: 1547146456086501955, guid: 59fb5021777d2914085416755ad69238, type: 3}
      line: "\xA1Puaj! Maldita sea, creo que estoy perdiendo pelo de los nervios.
        Se me queda pegado hasta en el cristal..."
    - character:
        name: Elvira
        icon: {fileID: -6177139537827096713, guid: 7f3b39185ede8c143932d888e56047ab, type: 3}
      line: "\xBFQui\xE9n apareci\xF3?"
    - character:
        name: Big Bear Romanov
        icon: {fileID: 1547146456086501955, guid: 59fb5021777d2914085416755ad69238, type: 3}
      line: "No importa. Voy a ver si mi viejo amigo Barnaby me invita a otra ronda
        en aquella mesa. Su billetera es m\xE1s grande que su boca."
  dialogoFinalizado:
    dialogueLines: []
  objetivoCumplido: 0
